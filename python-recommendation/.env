# Server Configuration
RECOMMENDATION_PORT=8001
RECOMMENDATION_HOST=0.0.0.0
DEBUG=True

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
